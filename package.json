{
  "name": "mcp-slim",
  "version": "0.1.0",
  "description": "MCP proxy that reduces context window usage by 80-95%",
  "main": "dist/index.js",
  "bin": {
    "mcp-slim": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "node dist/test/run-tests.js && node dist/test/run-phase2-tests.js",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "proxy",
    "context",
    "optimization"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
